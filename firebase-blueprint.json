{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application (Admin, Doctor, or Patient).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "doctor", "patient"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "A doctor profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "availability": {
          "type": "object",
          "properties": {
            "days": { "type": "array", "items": { "type": "string" } },
            "timeSlots": { "type": "array", "items": { "type": "string" } }
          }
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "specialization", "availability", "createdBy"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "An appointment between a patient and a doctor.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "specialization": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "completed"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "date", "time", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctor profile data."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment records."
    }
  }
}
